---
// Footer.astro — shared site footer. Edit once, updates everywhere.
const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Services", href: "/services" },
  { label: "Testimonials", href: "/testimonials" },
  { label: "FAQ", href: "/faq" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="bg-white px-5 py-16 sm:px-8 lg:px-12">
  <div class="mx-auto max-w-7xl">
    <div
      class="flex flex-col items-center gap-8 border-b border-neutral-200 pb-12 text-center"
    >
      <a href="/" aria-label="Meredith Lewis Photography — home">
        <img
          src="/logo.png"
          alt="Meredith Lewis Photography — based in the White Mountains, ME, NH &amp; VT, established 2019."
          width="760"
          height="485"
          class="h-64 w-auto sm:h-80"
        />
      </a>

      <nav aria-label="Footer" class="flex flex-wrap justify-center gap-x-6 gap-y-3">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-light tracking-wide text-neutral-800 transition-colors hover:text-neutral-900"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="https://www.facebook.com/share/1Ew67obhv6/?mibextid=wwXIfr"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit Meredith Lewis Photography on Facebook"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.89h2.54V9.797c0-2.507 1.492-3.892 3.777-3.892 1.094 0 2.238.196 2.238.196v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z"></path>
          </svg>
        </a>
        <a
          href="mailto:meredith.lewis2018@gmail.com"
          aria-label="Email Meredith Lewis Photography"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </a>
        <a
          href="https://meredithlewisphotography.pixieset.com/booking/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Book a session on Pixieset"
          class="flex h-10 items-center justify-center rounded-full border border-neutral-300 px-4 text-xs font-medium uppercase tracking-[0.18em] text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
        >
          Book
        </a>
      </div>
    </div>

    <p class="mt-8 text-center text-xs font-light tracking-wide text-neutral-700">
      &copy; {new Date().getFullYear()} Meredith Lewis Photography. All rights reserved.
    </p>
    <p class="mt-2 text-center text-xs font-light tracking-wide text-neutral-400">
      Website made by
      <a
        href="https://jakefixestech.com/web-services/"
        target="_blank"
        rel="noopener noreferrer"
        class="underline underline-offset-2 transition-colors hover:text-neutral-700"
      >
        Jake Fixes Tech
      </a>
    </p>
  </div>
</footer>
