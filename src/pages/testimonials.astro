---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Testimonials | Meredith Lewis Photography"
  description="Read what clients say about working with Meredith Lewis Photography, candid portrait and event photography throughout the White Mountains of New Hampshire."
  noindex={true}
>
  <section class="flex min-h-[70vh] items-center justify-center px-5 py-32 sm:px-8">
    <div class="mx-auto max-w-xl text-center">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
        Testimonials
      </p>
      <h1 class="font-serif text-4xl font-medium leading-tight text-neutral-900 text-balance sm:text-5xl">
        This page is coming together.
      </h1>
      <p class="mx-auto mt-8 max-w-md text-lg font-light leading-relaxed text-neutral-600 text-pretty">
        Hey Meredith! This is your full Testimonials page. It&apos;s a placeholder
        for now so the link from your home page has somewhere to go. I&apos;ll build
        it out with all of your reviews once we lock in the home page. Send over any
        extras you want included and I&apos;ll add them here.
      </p>
      <a
        href="/"
        class="mt-10 inline-block rounded-full bg-neutral-900 px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-white transition-colors hover:bg-neutral-700"
      >
        Back to Home
      </a>
    </div>
  </section>
</Layout>
