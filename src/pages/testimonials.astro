---
import Layout from "../layouts/Layout.astro";
import content from "../content/testimonials.json";
---

<Layout
  title="Client Testimonials | Meredith Lewis Photography"
  description="Read kind words from Meredith Lewis Photography clients. 100% recommended portrait and event photography throughout the White Mountains of New Hampshire, Maine, and Vermont."
>
  <!-- ===================== HEADER ===================== -->
  <section class="px-5 pt-12 pb-12 sm:px-8 sm:pt-16 sm:pb-16 lg:px-12">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
        {content.header_eyebrow}
      </p>
      <h1 class="font-serif text-4xl font-medium leading-tight text-neutral-900 text-balance sm:text-5xl">
        {content.header_heading}
      </h1>
      <p class="mx-auto mt-8 max-w-xl text-lg font-light leading-relaxed text-neutral-600 text-pretty">
        {content.header_intro}
      </p>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS (masonry) ===================== -->
  <section class="px-5 pb-24 sm:px-8 sm:pb-32 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="columns-1 gap-6 md:columns-2 lg:columns-3 [column-fill:balance]">
        {
          content.testimonials.map((t) => (
            <figure class="mb-6 break-inside-avoid border border-neutral-200 bg-neutral-50 p-7 sm:p-8">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="mb-4 h-7 w-7 text-neutral-300"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z" />
              </svg>
              <blockquote class="font-light leading-relaxed text-neutral-700 text-pretty">
                {t.quote}
              </blockquote>
              <figcaption class="mt-6 font-serif text-lg text-neutral-900">
                {t.author}
              </figcaption>
            </figure>
          ))
        }

        <!-- CTA card: flows into the masonry and fills the empty space -->
        <a
          href="https://www.facebook.com/meredithlewisphotography/reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="group mb-6 flex break-inside-avoid flex-col items-center justify-center bg-neutral-900 p-10 text-center transition-colors hover:bg-neutral-800"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="mb-5 h-9 w-9 text-white/80" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.89h2.54V9.797c0-2.507 1.492-3.892 3.777-3.892 1.094 0 2.238.196 2.238.196v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z" />
          </svg>
          <p class="font-serif text-xl font-medium leading-snug text-white text-balance">
            And many more happy clients.
          </p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-medium uppercase tracking-[0.15em] text-white/90 transition-colors group-hover:text-white">
            Read more on Facebook
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== CLOSING CTA ===================== -->
  <section class="bg-neutral-900 px-5 py-20 text-center sm:px-8 sm:py-24 lg:px-12">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-serif text-3xl font-medium leading-snug text-white text-balance sm:text-4xl">
        Let's create something you'll love too.
        <svg
          id="beat-heart"
          xmlns="http://www.w3.org/2000/svg"
          class="ml-1 inline-block h-7 w-7 align-baseline text-white sm:h-8 sm:w-8"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
        </svg>
      </h2>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-full bg-white px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-200"
      >
        Get in Touch
      </a>
    </div>
  </section>

  <style>
    /* Heart beat animation: a few beats then rests static. */
    @keyframes heart-beat {
      0%   { transform: scale(1); }
      18%  { transform: scale(1.28); }
      36%  { transform: scale(1); }
      54%  { transform: scale(1.22); }
      72%  { transform: scale(1); }
      100% { transform: scale(1); }
    }
    #beat-heart {
      transform-origin: center;
      opacity: 0;
      transform: scale(1);
      transition: opacity 1.2s ease-in-out;
    }
    /* When revealed: fade in slowly, then beat once the fade is done, then rest. */
    #beat-heart.is-visible {
      opacity: 1;
      animation: heart-beat 3s ease-in-out 1.4s 1 both;
    }
    /* Respect users who prefer reduced motion: just show it, no fade or beat. */
    @media (prefers-reduced-motion: reduce) {
      #beat-heart {
        transition: none;
        opacity: 1;
      }
      #beat-heart.is-visible {
        animation: none;
      }
    }
  </style>

  <script>
    // Trigger the heart beat when it scrolls into view (once).
    const heart = document.getElementById("beat-heart");
    if (heart) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              heart.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.6 }
      );
      observer.observe(heart);
    }
  </script>
</Layout>
