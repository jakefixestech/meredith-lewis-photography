---
import Layout from "../layouts/Layout.astro";
import SmartImage from "../components/SmartImage.astro";
import content from "../content/portfolio-seasonal-minis.json";

interface StorySet {
  set_title?: string;
  main_feature: string;
  right_top: string;
  right_bottom: string;
}

const rawContent = content as any;

const headerEyebrow = rawContent.header_eyebrow || "Galleries";
const headerHeading = rawContent.header_heading || "Seasonal Minis";
const headerIntro = rawContent.header_intro || "";
const heroBgImage = rawContent.hero_bg_image || "";
const heroBgAlt = rawContent.hero_bg_alt || "Seasonal Minis Banner";

const storySets = (rawContent.story_sets as StorySet[]) || [];
---

<Layout
  title={`${headerHeading} Portfolio | Meredith Lewis Photography`}
  description={headerIntro}
  solidNav={false}
>
  <section class="relative min-h-[70vh] flex items-center justify-center px-5 py-24 sm:px-8 lg:px-12 overflow-hidden bg-neutral-900">
    <div class="absolute inset-0 z-0">
      <SmartImage 
        src={heroBgImage} 
        alt={heroBgAlt} 
        class="h-full w-full object-cover object-center opacity-85"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-neutral-900/20"></div>
    </div>

    <div class="relative z-10 w-full max-w-2xl mx-auto rounded-sm bg-white/95 backdrop-blur-md p-8 sm:p-12 text-center shadow-xl border border-white/20">
      <span class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500">
        {headerEyebrow}
      </span>
      <h1 class="mt-4 font-serif text-3xl font-medium tracking-tight text-neutral-900 sm:text-4xl md:text-5xl">
        {headerHeading}
      </h1>
      <div class="mx-auto mt-6 h-px w-16 bg-neutral-300"></div>
      <p class="mt-6 text-base font-light leading-relaxed text-neutral-600 text-pretty">
        {headerIntro}
      </p>
    </div>
  </section>

  {storySets.map((set, rowIndex) => {
    const isEvenRow = rowIndex % 2 === 0;
    const baseIndex = rowIndex * 3;
    
    return (
      <section class={`w-full py-20 px-5 sm:px-8 lg:px-12 border-t border-neutral-100 ${isEvenRow ? 'bg-stone-50/40' : 'bg-white'}`}>
        <div class="mx-auto max-w-7xl">
          
          <div class="mb-10 border-b pb-4 border-neutral-300 max-w-xs">
            <h2 class="text-sm font-sans font-semibold uppercase tracking-[0.15em] text-neutral-800 sm:text-base">
              {set.set_title || `Featured Story Set — ${rowIndex + 1}`}
            </h2>
          </div>

          <div class="grid grid-cols-1 gap-8 lg:grid-cols-3 w-full items-start">
            
            {/* Left Column: Big Feature Image */}
            {set.main_feature && (
              <div class="lg:col-span-2 w-full">
                <div 
                  class="portfolio-item overflow-hidden rounded-sm group cursor-pointer bg-neutral-100 dark:bg-neutral-900 shadow-sm transition-all duration-300 hover:shadow-md"
                  data-image-src={set.main_feature}
                  data-image-alt={`${set.set_title || 'Story Set'} - Main Feature`}
                  data-index={baseIndex}
                >
                  <div class="overflow-hidden bg-neutral-100 dark:bg-neutral-900">
                    <SmartImage
                      src={set.main_feature}
                      alt={`${set.set_title || 'Story Set'} - Main Feature`}
                      class="portfolio-img h-auto w-full object-contain transition-transform duration-700 ease-out group-hover:scale-[1.015]"
                    />
                  </div>
                </div>
              </div>
            )}

            {/* Right Column: Stackable side panels */}
            <div class="lg:col-span-1 flex flex-col gap-8 w-full">
              {set.right_top && (
                <div 
                  class="portfolio-item overflow-hidden rounded-sm group cursor-pointer bg-neutral-100 dark:bg-neutral-900 shadow-sm transition-all duration-300 hover:shadow-md w-full"
                  data-image-src={set.right_top}
                  data-image-alt={`${set.set_title || 'Story Set'} - Right Top`}
                  data-index={baseIndex + 1}
                >
                  <div class="overflow-hidden bg-neutral-100 dark:bg-neutral-900 aspect-[3/2]">
                    <SmartImage
                      src={set.right_top}
                      alt={`${set.set_title || 'Story Set'} - Right Top`}
                      class="portfolio-img h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.015]"
                    />
                  </div>
                </div>
              )}

              {set.right_bottom && (
                <div 
                  class="portfolio-item overflow-hidden rounded-sm group cursor-pointer bg-neutral-100 dark:bg-neutral-900 shadow-sm transition-all duration-300 hover:shadow-md w-full"
                  data-image-src={set.right_bottom}
                  data-image-alt={`${set.set_title || 'Story Set'} - Right Bottom`}
                  data-index={baseIndex + 2}
                >
                  <div class="overflow-hidden bg-neutral-100 dark:bg-neutral-900 aspect-[3/2]">
                    <SmartImage
                      src={set.right_bottom}
                      alt={`${set.set_title || 'Story Set'} - Right Bottom`}
                      class="portfolio-img h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.015]"
                    />
                  </div>
                </div>
              )}
            </div>

          </div>

        </div>
      </section>
    );
  })}

  <section class="bg-neutral-950 px-5 py-24 sm:px-8 sm:py-28 lg:px-12 text-white border-t border-neutral-900">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-2xl font-light tracking-wide text-neutral-100 sm:text-3xl">
        {content.cta_box_title}
      </h2>
      <p class="mt-6 text-sm font-light leading-relaxed text-neutral-400 text-pretty">
        {content.cta_box_text}
      </p>
      <div class="mt-10">
        <a 
          href="/contact" 
          class="inline-block rounded-full bg-white px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-200"
        >
          {content.cta_button_label}
        </a>
      </div>
    </div>
  </section>

  <div
    id="lightbox"
    class="fixed inset-0 z-[100] hidden flex-col items-center justify-center bg-black/95 p-4 opacity-0 transition-opacity duration-300 backdrop-blur-sm select-none"
    role="dialog"
    aria-label="Image viewer"
    aria-hidden="true"
  >
    <button id="lightbox-close" class="absolute top-6 right-6 z-[110] text-white/70 hover:text-white p-2"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg></button>
    <div class="relative flex h-full w-full max-w-6xl items-center justify-center px-12">
      <button id="lightbox-prev" class="absolute left-4 z-[110] hidden sm:flex text-white/50 hover:text-white p-4 rounded-full hover:bg-white/5"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg></button>
      <div class="relative max-h-[85vh] max-w-[90vw] flex items-center justify-center">
        <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-sm shadow-2xl pointer-events-none" />
      </div>
      <button id="lightbox-next" class="absolute right-4 z-[110] hidden sm:flex text-white/50 hover:text-white p-4 rounded-full hover:bg-white/5"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg></button>
    </div>
  </div>
</Layout>

<script>
  function initLightbox() {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    
    const items = Array.from(document.querySelectorAll('.portfolio-item')).sort((a, b) => {
      return parseInt(a.getAttribute('data-index') || '0', 10) - parseInt(b.getAttribute('data-index') || '0', 10);
    });

    if (!lightbox || !lightboxImg || items.length === 0) return;

    let currentIndex = 0;
    let touchStartX = 0;
    let touchEndX = 0;

    const openLightbox = (index: number) => {
      currentIndex = index;
      updateLightboxContent();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      setTimeout(() => { lightbox.classList.remove('opacity-0'); lightbox.classList.add('opacity-100'); }, 10);
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.classList.remove('opacity-100');
      lightbox.classList.add('opacity-0');
      setTimeout(() => { lightbox.classList.remove('flex'); lightbox.classList.add('hidden'); }, 300);
      document.body.style.overflow = '';
    };

    const showNext = () => { currentIndex = (currentIndex + 1) % items.length; updateLightboxContent(); };
    const showPrev = () => { currentIndex = (currentIndex - 1 + items.length) % items.length; updateLightboxContent(); };

    const updateLightboxContent = () => {
      const wrapper = items[currentIndex] as HTMLElement;
      if (wrapper) {
        lightboxImg.src = wrapper.getAttribute('data-image-src') || '';
        lightboxImg.alt = wrapper.getAttribute('data-image-alt') || '';
      }
    };

    lightbox.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    lightbox.addEventListener('touchend', (e: TouchEvent) => { touchEndX = e.changedTouches[0].screenX; const dist = touchEndX - touchStartX; if (dist < -50) showNext(); if (dist > 50) showPrev(); }, { passive: true });

    items.forEach((item, index) => {
      const newItem = item.cloneNode(true);
      item.parentNode?.replaceChild(newItem, item);
      newItem.addEventListener('click', () => openLightbox(index));
    });

    closeBtn?.addEventListener('click', closeLightbox);
    nextBtn?.addEventListener('click', showNext);
    prevBtn?.addEventListener('click', showPrev);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (lightbox.classList.contains('hidden')) return; if (e.key === 'Escape') closeLightbox(); if (e.key === 'ArrowRight') showNext(); if (e.key === 'ArrowLeft') showPrev(); });
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>