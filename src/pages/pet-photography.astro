---
import Layout from "../layouts/Layout.astro";
import SmartImage from "../components/SmartImage.astro";
import content from "../content/portfolio-pets.json";
---

<Layout
  title="Pets Photography Portfolio | Meredith Lewis Photography"
  description="Heartwarming and natural pet photography sessions in Dalton, Littleton, and across the White Mountains, NH."
  solidNav={true}
>
  <section class="bg-white px-5 py-20 text-center sm:px-8 sm:py-24 lg:px-12">
    <div class="mx-auto max-w-3xl">
      <span class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-400">
        {content.header_eyebrow}
      </span>
      <h1 class="mt-3 font-serif text-4xl font-medium tracking-tight text-neutral-900 sm:text-5xl">
        {content.header_heading}
      </h1>
      <div class="mx-auto mt-6 h-px w-16 bg-neutral-300"></div>
      <p class="mt-6 text-base font-light leading-relaxed text-neutral-600 text-pretty">
        {content.header_intro}
      </p>
    </div>
  </section>

  <section class="bg-white px-5 pb-20 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-8xl">
      {content.gallery && content.gallery.length > 0 ? (
        <div class="columns-1 gap-5 sm:columns-2 lg:columns-3 [&>div]:mb-5">
          {content.gallery.map((item, index) => (
            <div 
              class="gallery-item break-inside-avoid overflow-hidden rounded-sm bg-neutral-100 transition-transform duration-300 hover:scale-[1.01] cursor-pointer"
              data-index={index}
            >
              <SmartImage
                src={(item as any).image}
                alt={(item as any).title || (item as any).alt || "Pet Portfolio Photo"}
                width={800}
                class="portfolio-img h-auto w-full object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="py-12 text-center text-neutral-400 font-light">
          <p>Images are currently being loaded into this collection. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

  <section class="bg-neutral-950 px-5 py-24 sm:px-8 sm:py-28 lg:px-12 text-white border-t border-neutral-900">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-serif text-3xl font-light tracking-wide text-neutral-100 sm:text-4xl">
        {content.eol_heading}
      </h2>
      <div class="mx-auto mt-6 h-px w-12 bg-neutral-800"></div>
      
      <div class="mt-8 space-y-6 text-base font-light leading-relaxed text-neutral-300 max-w-2xl mx-auto">
        <p class="text-pretty">{content.eol_paragraph_1}</p>
        <p class="text-pretty">{content.eol_paragraph_2}</p>
      </div>

      <div class="mx-auto mt-12 max-w-xl rounded-sm bg-neutral-900 p-6 shadow-xl border border-neutral-800 text-left sm:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-neutral-400">Session Guidelines</p>
        <p class="mt-4 text-sm font-light leading-relaxed text-neutral-300">
          {content.eol_qualify_text}
        </p>
        <p class="mt-5 text-sm font-light italic text-neutral-400 border-t border-neutral-800 pt-4">
          {content.eol_share_text}
        </p>
      </div>

      <div class="mt-12">
        <a 
          href="/contact" 
          class="inline-block rounded-full bg-white px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-200"
        >
          {content.eol_cta_label}
        </a>
      </div>
    </div>
  </section>

  <div 
    id="lightbox" 
    class="fixed inset-0 z-[100] hidden flex-col items-center justify-center bg-black/95 p-4 opacity-0 transition-opacity duration-300 backdrop-blur-sm select-none animate-none"
    role="dialog"
    aria-label="Image viewer"
    aria-hidden="true"
  >
    <button id="lightbox-close" class="absolute top-6 right-6 z-[110] text-white/70 hover:text-white transition-colors focus:outline-none p-2" aria-label="Close image viewer">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
    </button>

    <button id="lightbox-prev" class="absolute left-4 z-[110] hidden sm:flex text-white/50 hover:text-white transition-colors focus:outline-none p-4 rounded-full hover:bg-white/5" aria-label="Previous image">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
    </button>

    <div class="relative max-h-[85vh] max-w-[90vw] flex items-center justify-center">
      <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-sm shadow-2xl pointer-events-none"/>
    </div>

    <button id="lightbox-next" class="absolute right-4 z-[110] hidden sm:flex text-white/50 hover:text-white transition-colors focus:outline-none p-4 rounded-full hover:bg-white/5" aria-label="Next image">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
    </button>
  </div>
</Layout>

<script>
  const items = document.querySelectorAll('.gallery-item');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');
  
  let currentIndex = 0;
  let touchStartX = 0;
  let touchEndX = 0;
  const minSwipeDistance = 50;

  if (lightbox && lightboxImg && items.length > 0) {
    const openLightbox = (index: number) => {
      currentIndex = index;
      updateLightboxContent();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      lightbox.setAttribute('aria-hidden', 'false');
      setTimeout(() => {
        lightbox.classList.remove('opacity-0');
        lightbox.classList.add('opacity-100');
      }, 10);
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.classList.remove('opacity-100');
      lightbox.classList.add('opacity-0');
      lightbox.setAttribute('aria-hidden', 'true');
      setTimeout(() => {
        lightbox.classList.remove('flex');
        lightbox.classList.add('hidden');
      }, 300);
      document.body.style.overflow = '';
    };

    const showNext = () => {
      currentIndex = (currentIndex + 1) % items.length;
      updateLightboxContent();
    };

    const showPrev = () => {
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      updateLightboxContent();
    };

    const updateLightboxContent = () => {
      const currentWrapper = items[currentIndex];
      const targetImg = currentWrapper?.querySelector('.portfolio-img') as HTMLImageElement;
      if (targetImg) {
        lightboxImg.src = targetImg.currentSrc || targetImg.src;
        lightboxImg.alt = targetImg.alt || '';
      }
    };

    const handleGesture = () => {
      const swipeDistance = touchEndX - touchStartX;
      if (swipeDistance < -minSwipeDistance) showNext();
      if (swipeDistance > minSwipeDistance) showPrev();
    };

    lightbox.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e: TouchEvent) => {
      touchEndX = e.changedTouches[0].screenX;
      handleGesture();
    }, { passive: true });

    items.forEach((item, index) => {
      item.addEventListener('click', () => openLightbox(index));
    });

    closeBtn?.addEventListener('click', closeLightbox);
    nextBtn?.addEventListener('click', showNext);
    prevBtn?.addEventListener('click', showPrev);

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
    });
  }
</script>