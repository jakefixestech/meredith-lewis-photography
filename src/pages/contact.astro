---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact | Meredith Lewis Photography"
  description="Get in touch with Meredith Lewis Photography to book a session or ask a question. Serving the White Mountains of New Hampshire, Maine, and Vermont."
  noindex={true}
>
  <section class="flex min-h-[70vh] items-center justify-center px-5 py-32 sm:px-8">
    <div class="mx-auto max-w-xl text-center">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
        Contact
      </p>
      <h1 class="font-serif text-4xl font-medium leading-tight text-neutral-900 text-balance sm:text-5xl">
        Let's connect.
      </h1>
      <p class="mx-auto mt-8 max-w-md text-lg font-light leading-relaxed text-neutral-600 text-pretty">
        Hey Meredith! This page is ready to be built out. When you have a moment,
        head to the Google Drive, open the <strong>"Contact"</strong> folder,
        and drop in any photos you&apos;d like featured here. Once your photos are in,
        I&apos;ll lay the page out, and you&apos;ll be able to swap images yourself
        anytime from your editor.
      </p>
      <a
        href="/"
        class="mt-10 inline-block rounded-full bg-neutral-900 px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-white transition-colors hover:bg-neutral-700"
      >
        Back to Home
      </a>
    </div>
  </section>
</Layout>
