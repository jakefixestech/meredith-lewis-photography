---
import Layout from "../layouts/Layout.astro";
import content from "../content/contact.json";
---

<Layout
  title="Contact | Meredith Lewis Photography"
  description="Get in touch with Meredith Lewis Photography to book a session or ask a question. Serving the White Mountains of New Hampshire, Maine, and Vermont."
>
  <!-- ===================== HEADER ===================== -->
  <section class="px-5 pt-12 pb-10 sm:px-8 sm:pt-16 sm:pb-12 lg:px-12">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
        {content.header_eyebrow}
      </p>
      <h1 class="font-serif text-4xl font-medium leading-tight text-neutral-900 text-balance sm:text-5xl">
        {content.header_heading}
      </h1>
      <p class="mx-auto mt-8 max-w-xl text-lg font-light leading-relaxed text-neutral-600 text-pretty">
        {content.header_intro}
      </p>
    </div>
  </section>

  <!-- ===================== TWO COLUMN: INFO + FORM ===================== -->
  <section class="px-5 pb-24 sm:px-8 sm:pb-32 lg:px-12">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-5 lg:gap-16">
      <!-- LEFT: contact details + Pixieset -->
      <div class="lg:col-span-2">
        <h2 class="font-serif text-2xl font-medium text-neutral-900">
          {content.info_heading}
        </h2>
        <dl class="mt-8 space-y-6">
          <div>
            <dt class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500">
              Email
            </dt>
            <dd class="mt-2">
              <a
                href="mailto:meredith.lewis2018@gmail.com"
                class="font-light text-neutral-800 underline underline-offset-4 transition-colors hover:text-neutral-500"
              >
                meredith.lewis2018@gmail.com
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500">
              Based In
            </dt>
            <dd class="mt-2">
              <a
                href="https://www.google.com/maps/place/Dalton,+NH"
                target="_blank"
                rel="noopener noreferrer"
                class="font-light text-neutral-800 underline underline-offset-4 transition-colors hover:text-neutral-500"
              >
                Dalton, New Hampshire
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500">
              Follow Along
            </dt>
            <dd class="mt-3">
              <a
                href="https://www.facebook.com/share/1Ew67obhv6/?mibextid=wwXIfr"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Meredith Lewis Photography on Facebook"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.89h2.54V9.797c0-2.507 1.492-3.892 3.777-3.892 1.094 0 2.238.196 2.238.196v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z"></path>
                </svg>
              </a>
            </dd>
          </div>
        </dl>

        <!-- Pixieset booking -->
        <div class="mt-10 border-t border-neutral-200 pt-8">
          <p class="text-sm font-light leading-relaxed text-neutral-600">
            {content.booking_text}
          </p>
          <a
            href="https://meredithlewisphotography.pixieset.com/booking/"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-block rounded-full bg-neutral-900 px-7 py-3 text-sm font-medium uppercase tracking-[0.15em] text-white transition-colors hover:bg-neutral-700"
          >
            Book a Session
          </a>
        </div>
      </div>

      <!-- RIGHT: contact form -->
      <div class="lg:col-span-3">
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-6"
        >
          <!-- Web3Forms access key: replace placeholder once Meredith provides hers -->
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
          <input type="hidden" name="subject" value="New inquiry from Meredith Lewis Photography" />
          <input type="hidden" name="from_name" value="Meredith Lewis Photography Website" />
          <!-- Honeypot spam protection -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label for="first_name" class="block text-xs font-medium uppercase tracking-[0.2em] text-neutral-600">
                First Name <span class="text-neutral-400">*</span>
              </label>
              <input
                type="text"
                id="first_name"
                name="first_name"
                required
                class="mt-2 w-full border border-neutral-300 bg-white px-4 py-3 text-neutral-900 transition-colors focus:border-neutral-900 focus:outline-none"
              />
            </div>
            <div>
              <label for="last_name" class="block text-xs font-medium uppercase tracking-[0.2em] text-neutral-600">
                Last Name <span class="text-neutral-400">*</span>
              </label>
              <input
                type="text"
                id="last_name"
                name="last_name"
                required
                class="mt-2 w-full border border-neutral-300 bg-white px-4 py-3 text-neutral-900 transition-colors focus:border-neutral-900 focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-xs font-medium uppercase tracking-[0.2em] text-neutral-600">
              Email <span class="text-neutral-400">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-2 w-full border border-neutral-300 bg-white px-4 py-3 text-neutral-900 transition-colors focus:border-neutral-900 focus:outline-none"
            />
          </div>

          <div>
            <label for="session_type" class="block text-xs font-medium uppercase tracking-[0.2em] text-neutral-600">
              Session Type
            </label>
            <select
              id="session_type"
              name="session_type"
              class="mt-2 w-full border border-neutral-300 bg-white px-4 py-3 text-neutral-900 transition-colors focus:border-neutral-900 focus:outline-none"
            >
              <option value="">Select a session type</option>
              <option value="Senior Portraits">Senior Portraits</option>
              <option value="Couples">Couples</option>
              <option value="Engagement">Engagement</option>
              <option value="Family">Family</option>
              <option value="Maternity">Maternity</option>
              <option value="Pet Photography">Pet Photography</option>
              <option value="Events & Parties">Events &amp; Parties</option>
              <option value="Seasonal Mini Sessions">Seasonal Mini Sessions</option>
              <option value="Other">Other / Not Sure</option>
            </select>
          </div>

          <div>
            <label for="subject" class="block text-xs font-medium uppercase tracking-[0.2em] text-neutral-600">
              Subject
            </label>
            <input
              type="text"
              id="subject"
              name="subject_line"
              class="mt-2 w-full border border-neutral-300 bg-white px-4 py-3 text-neutral-900 transition-colors focus:border-neutral-900 focus:outline-none"
            />
          </div>

          <div>
            <label for="message" class="block text-xs font-medium uppercase tracking-[0.2em] text-neutral-600">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="6"
              class="mt-2 w-full border border-neutral-300 bg-white px-4 py-3 text-neutral-900 transition-colors focus:border-neutral-900 focus:outline-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-full bg-neutral-900 px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-white transition-colors hover:bg-neutral-700 sm:w-auto"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
