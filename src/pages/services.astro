---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Services & Pricing | Meredith Lewis Photography"
  description="Session types and pricing for Meredith Lewis Photography — senior portraits, couples, engagement, family, maternity, pet, and event photography throughout the White Mountains of New Hampshire."
  noindex={true}
>
  <section class="flex min-h-[70vh] items-center justify-center px-5 py-32 sm:px-8">
    <div class="mx-auto max-w-xl text-center">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
        Services &amp; Pricing
      </p>
      <h1 class="font-serif text-4xl font-medium leading-tight text-neutral-900 text-balance sm:text-5xl">
        Coming soon.
      </h1>
      <p class="mx-auto mt-8 max-w-md text-lg font-light leading-relaxed text-neutral-600 text-pretty">
        I&apos;m putting the finishing touches on my full list of sessions, pricing,
        and seasonal mini sessions. Check back shortly — or reach out anytime and
        I&apos;ll happily walk you through it.
      </p>
      <a
        href="/contact"
        class="mt-10 inline-block rounded-full bg-neutral-900 px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-white transition-colors hover:bg-neutral-700"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
