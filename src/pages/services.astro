---
import Layout from "../layouts/Layout.astro";
import SmartImage from "../components/SmartImage.astro";
import content from "../content/services.json";
---

<Layout
  title="Services & Pricing | Meredith Lewis Photography"
  description="Photography session types and pricing with Meredith Lewis Photography. Senior portraits, couples, engagement, family, maternity, pet, and event photography throughout the White Mountains of New Hampshire."
>
  <!-- ===================== HEADER ===================== -->
  <section class="px-5 pt-12 pb-12 sm:px-8 sm:pt-16 sm:pb-16 lg:px-12">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
        {content.header_eyebrow}
      </p>
      <h1 class="font-serif text-4xl font-medium leading-tight text-neutral-900 text-balance sm:text-5xl">
        {content.header_heading}
      </h1>
      <p class="mx-auto mt-8 max-w-2xl text-lg font-light leading-relaxed text-neutral-600 text-pretty">
        {content.header_intro}
      </p>
      <p class="mx-auto mt-6 max-w-xl text-sm font-medium uppercase tracking-[0.15em] text-neutral-500">
        {content.header_subnote}
      </p>
    </div>
  </section>

  <!-- ===================== SERVICE CARDS ===================== -->
  <section class="px-5 pb-24 sm:px-8 sm:pb-32 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-x-10 gap-y-16 sm:grid-cols-2">
        {
          content.services.map((s) => {
            const Tag = s.link ? "a" : "div";
            return (
              <Tag
                href={s.link || undefined}
                class={`group flex flex-col ${s.link ? "cursor-pointer" : ""}`}
              >
                <div class="overflow-hidden bg-neutral-100">
                  <SmartImage
                    src={s.image}
                    alt={s.alt}
                    width={900}
                    height={675}
                    loading="lazy"
                    class="aspect-[4/3] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  />
                </div>
                <div class="mt-6">
                  <div class="flex items-baseline justify-between gap-4 border-b border-neutral-200 pb-4">
                    <h2 class="font-serif text-2xl font-medium text-neutral-900">
                      {s.name}
                    </h2>
                    <span class="font-serif text-xl text-neutral-500 tabular-nums">
                      {s.price}
                    </span>
                  </div>
                  <p class="mt-5 text-base font-light leading-relaxed text-neutral-600 text-pretty">
                    {s.description}
                  </p>
                  {s.link && (
                    <span class="mt-4 inline-block text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 underline underline-offset-4 transition-colors group-hover:text-neutral-500">
                      View Seasonal Minis
                    </span>
                  )}
                </div>
              </Tag>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ===================== PURCHASING ADDITIONAL PHOTOS ===================== -->
  <section class="relative px-5 py-28 sm:px-8 sm:py-32 lg:px-12">
    <!-- Background photo (editable in Decap) -->
    <SmartImage
      src={content.addons_bg}
      alt={content.addons_bg_alt}
      width={1600}
      height={900}
      loading="lazy"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <!-- Dark scrim for legibility -->
    <div class="absolute inset-0 bg-black/65"></div>

    <div class="relative z-10 mx-auto max-w-6xl">
      <div class="mb-14 text-center">
        <p class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-white/70">
          {content.addons_eyebrow}
        </p>
        <h2 class="font-serif text-3xl font-medium text-white sm:text-4xl">
          {content.addons_heading}
        </h2>
      </div>

      <div class="grid gap-12 sm:grid-cols-3">
        {
          content.addons.map((a) => (
            <div class="text-center">
              <h3 class="font-serif text-xl font-medium text-white">
                {a.title}
              </h3>
              <p class="mx-auto mt-5 max-w-xs text-base font-light leading-relaxed text-white/80 text-pretty">
                {a.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== CLOSING CTA ===================== -->
  <section class="bg-neutral-900 px-5 py-20 text-center sm:px-8 sm:py-24 lg:px-12">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-serif text-3xl font-medium leading-snug text-white text-balance sm:text-4xl">
        Ready to book your session?
      </h2>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-full bg-white px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-200"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
