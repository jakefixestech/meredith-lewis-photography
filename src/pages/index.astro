---
import Layout from "../layouts/Layout.astro";
import content from "../content/homepage.json";
import SmartImage from "../components/SmartImage.astro";
---

<Layout
  title="Meredith Lewis Photography | White Mountains, NH"
  description="Meredith Lewis Photography — capturing candid, heartfelt moments throughout the White Mountains of New Hampshire, Maine, and Vermont. Approachable, affordable portrait and event photography."
  solidNav={false}
>
  <!-- ===================== HERO ===================== -->
  <section id="home" class="relative h-screen min-h-[600px] w-full">
    <SmartImage
      src={content.hero_image}
      alt={content.hero_image_alt}
      width={1600}
      height={1000}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <!-- Dark gradient scrim at the bottom for legibility -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/10"
    >
    </div>
    <!-- Soft top scrim so the nav reads over the bright sky -->
    <div
      class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-black/50 to-transparent"
    >
    </div>

    <div
      class="relative z-10 mx-auto flex h-full max-w-7xl flex-col justify-end px-5 pb-24 sm:px-8 sm:pb-28 lg:px-12"
    >
      <h1
        class="max-w-3xl font-serif text-3xl font-medium leading-tight text-white text-balance [text-shadow:0_2px_16px_rgba(0,0,0,0.55)] sm:text-4xl md:text-4xl lg:text-5xl"
      >
        {content.hero_heading}
      </h1>
    </div>

    <!-- Scroll-down cue -->
    <a
      href="#about"
      aria-label="Scroll down to learn more"
      class="absolute bottom-8 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 text-white/80 transition-colors hover:text-white"
    >
      <span class="text-[11px] font-light uppercase tracking-[0.25em]">Scroll</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 animate-bounce"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </a>
  </section>

  <!-- ===================== INTRO / ABOUT ===================== -->
  <section id="about" class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="order-1 lg:order-none">
        <SmartImage
          src={content.about_photo}
          alt={content.about_photo_alt}
          width={1000}
          height={1250}
          loading="lazy"
          class="aspect-[4/5] w-full rounded-sm object-cover"
        />
      </div>
      <div class="text-center lg:text-left">
        <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
          {content.about_eyebrow}
        </p>
        <h2 class="font-serif text-3xl font-medium leading-snug text-neutral-900 text-balance sm:text-4xl">
          {content.about_heading}
        </h2>
        <div class="mx-auto mt-8 max-w-xl space-y-5 text-lg font-light leading-relaxed text-neutral-600 text-pretty lg:mx-0">
          {content.about_paragraphs.map((para) => <p>{para}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== PORTFOLIO ===================== -->
  <section
    id="portfolio"
    class="bg-neutral-50 px-5 py-24 sm:px-8 sm:py-28 lg:px-12"
  >
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-col gap-3 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="mb-3 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
            {content.portfolio_eyebrow}
          </p>
          <h2 class="font-serif text-3xl font-medium tracking-tight text-neutral-900 sm:text-4xl">
            {content.portfolio_heading}
          </h2>
        </div>
        <p class="max-w-sm text-sm leading-relaxed text-neutral-500">
          {content.portfolio_blurb}
        </p>
      </div>

      <div class="grid auto-rows-[180px] grid-cols-1 gap-4 sm:auto-rows-[220px] sm:grid-cols-2 md:grid-cols-4">
        {
          content.galleries.map((g, i) => (
            <a
              href={g.href}
              class={`group relative block overflow-hidden bg-neutral-100 ${g.span}`}
            >
              <SmartImage
                src={g.img}
                alt={g.alt}
                width={800}
                height={1000}
                loading={i < 2 ? "eager" : "lazy"}
                class={`h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 ${g.ratio}`}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/70 via-neutral-900/0 to-transparent" />
              <div class="absolute inset-x-0 bottom-0 flex items-center justify-between p-4">
                <h3 class="font-serif text-lg text-white drop-shadow-sm sm:text-xl">
                  {g.title}
                </h3>
                <span class="text-xs font-medium uppercase tracking-[0.2em] text-white/80 opacity-0 transition-opacity group-hover:opacity-100">
                  View
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES & PRICING ===================== -->
  <section id="services" class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12">
    <div class="mx-auto max-w-3xl">
      <div class="mb-12 text-center">
        <p class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
          {content.services_eyebrow}
        </p>
        <h2 class="font-serif text-3xl font-medium text-neutral-900 sm:text-4xl">
          {content.services_heading}
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-base font-light leading-relaxed text-neutral-600 text-pretty">
          {content.services_blurb}
        </p>
      </div>

      <ul class="divide-y divide-neutral-200 border-y border-neutral-200">
        {
          content.services.map((s) => (
            <li class="flex items-baseline justify-between gap-4 py-5">
              <span class="font-serif text-xl text-neutral-900">{s.name}</span>
              <span aria-hidden="true" class="mx-3 hidden flex-1 border-b border-dotted border-neutral-300 sm:block"></span>
              <span class="tabular-nums text-neutral-600">{s.price}</span>
            </li>
          ))
        }
      </ul>

      <p class="mt-8 text-center text-sm font-light leading-relaxed text-neutral-500 text-pretty">
        {content.services_footnote}
      </p>
      <div class="mt-10 text-center">
        <a
          href="/services"
          class="inline-block rounded-full border border-neutral-900 px-7 py-3 text-sm font-light uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-900 hover:text-white"
        >
          View Full Services
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== PAY WHAT YOU CAN BAND ===================== -->
  <section
    id="mini-sessions"
    class="bg-neutral-900 px-5 py-24 text-center sm:px-8 sm:py-28 lg:px-12"
  >
    <div class="mx-auto max-w-3xl">
      <p
        class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500"
      >
        {content.minis_eyebrow}
      </p>
      <h2
        class="font-serif text-3xl font-medium leading-snug text-white text-balance sm:text-4xl"
      >
        {content.minis_heading}
      </h2>
      <p
        class="mx-auto mt-8 max-w-2xl text-lg font-light leading-relaxed text-neutral-300 text-pretty"
      >
        {content.minis_body_before}
        <span class="text-white">{content.minis_body_emphasis}</span>
        {content.minis_body_after}
      </p>
      <a
        href={content.minis_button_href}
        class="mt-10 inline-block rounded-full border border-white/70 px-7 py-3 text-sm font-light uppercase tracking-[0.15em] text-white transition-colors hover:bg-white hover:text-neutral-900"
      >
        {content.minis_button_label}
      </a>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS CAROUSEL ===================== -->
  <section
    id="testimonials"
    class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12"
  >
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 flex flex-col gap-4 text-center sm:flex-row sm:items-end sm:justify-between sm:text-left">
        <div>
          <p class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
            {content.testimonials_eyebrow}
          </p>
          <h2 class="font-serif text-3xl font-medium text-neutral-900 sm:text-4xl">
            {content.testimonials_heading}
          </h2>
        </div>
        <div class="flex items-center justify-center gap-3 sm:justify-end">
          <button
            id="tst-prev"
            type="button"
            aria-label="Previous testimonial"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </button>
          <button
            id="tst-next"
            type="button"
            aria-label="Next testimonial"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </button>
        </div>
      </div>

      <div
        id="tst-track"
        class="flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth pb-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      >
        {
          content.testimonials.map((t) => (
            <figure class="w-[85%] flex-shrink-0 snap-start border border-neutral-200 bg-neutral-50 p-8 sm:w-[60%] sm:p-10 lg:w-[46%]">
              <blockquote class="font-serif text-lg font-normal italic leading-relaxed text-neutral-800 text-pretty sm:text-xl">
                &ldquo;{t.quote}&rdquo;
              </blockquote>
              <figcaption class="mt-6 text-sm font-medium uppercase tracking-[0.2em] text-neutral-500">
                — {t.author}
              </figcaption>
            </figure>
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href={content.testimonials_link_href}
          class="inline-block text-sm font-medium uppercase tracking-[0.2em] text-neutral-900 underline underline-offset-4 transition-colors hover:text-neutral-600"
        >
          {content.testimonials_link_label}
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== CLOSING CTA ===================== -->
  <section id="contact" class="relative w-full">
    <SmartImage
      src={content.cta_image}
      alt={content.cta_image_alt}
      width={1600}
      height={900}
      loading="lazy"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>

    <div
      class="relative z-10 mx-auto flex max-w-3xl flex-col items-center px-5 py-32 text-center sm:px-8 sm:py-40 lg:px-12"
    >
      <h2
        class="font-serif text-4xl font-medium leading-tight text-white text-balance sm:text-5xl"
      >
        {content.cta_heading}
      </h2>
      <p
        class="mt-6 max-w-xl text-lg font-light leading-relaxed text-white/80 text-pretty"
      >
        {content.cta_text}
      </p>
      <a
        href={content.cta_button_href}
        class="mt-10 inline-block rounded-full bg-white px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-200"
      >
        {content.cta_button_label}
      </a>
    </div>
  </section>

  <!-- ===================== HOME-SPECIFIC JS (carousel only) ===================== -->
  <script>
    // Testimonial carousel — home page only
    const tstTrack = document.getElementById("tst-track");
    const tstPrev = document.getElementById("tst-prev");
    const tstNext = document.getElementById("tst-next");

    if (tstTrack && tstPrev && tstNext) {
      const scrollByCard = (dir: number) => {
        const card = tstTrack.querySelector("figure");
        const amount = card ? card.offsetWidth + 24 : tstTrack.clientWidth * 0.8;
        tstTrack.scrollBy({ left: dir * amount, behavior: "smooth" });
      };
      tstPrev.addEventListener("click", () => scrollByCard(-1));
      tstNext.addEventListener("click", () => scrollByCard(1));
    }
  </script>
</Layout>
