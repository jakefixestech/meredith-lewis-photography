---
import "../styles/global.css";
import content from "../content/homepage.json";
import SmartImage from "../components/SmartImage.astro";

// Nav + footer stay hardcoded on purpose — Meredith edits page content, not site chrome.
const navLinks = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Portfolio", href: "#portfolio" },
  { label: "Services", href: "#services" },
  { label: "Testimonials", href: "#testimonials" },
  { label: "Contact", href: "#contact" },
];
---

<!doctype html>
<html lang="en" class="bg-white scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Meredith Lewis Photography — capturing candid, heartfelt moments throughout the White Mountains of New Hampshire, Maine, and Vermont. Approachable, affordable portrait and event photography."
    />
    <title>Meredith Lewis Photography | White Mountains, NH</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />

    <!-- Google Fonts: Playfair Display (serif) + Inter (sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --font-serif: "Playfair Display", Georgia, serif;
        --font-sans: "Inter", system-ui, sans-serif;
      }
      body {
        font-family: var(--font-sans);
      }
      .font-serif {
        font-family: var(--font-serif);
      }
    </style>
  </head>

  <body class="bg-white text-neutral-900 antialiased">
    <!-- ===================== NAV ===================== -->
    <header
      id="site-nav"
      class="fixed inset-x-0 top-0 z-50 transition-colors duration-300"
    >
      <nav
        aria-label="Primary"
        class="mx-auto flex max-w-7xl items-center justify-between px-5 py-5 sm:px-8 lg:px-12"
      >
        <a
          href="#home"
          id="wordmark"
          class="font-serif text-lg font-medium tracking-tight text-white transition-colors duration-300 sm:text-xl"
        >
          Meredith Lewis Photography
        </a>

        <!-- Desktop nav -->
        <div class="hidden items-center gap-8 lg:flex">
          <ul class="flex items-center gap-7">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="nav-link text-sm font-light tracking-wide text-white/90 transition-colors duration-300 hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <a
            href="#contact"
            class="nav-cta rounded-full border border-white/70 px-5 py-2 text-sm font-light tracking-wide text-white transition-colors duration-300 hover:bg-white hover:text-neutral-900"
          >
            Get in Touch
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          type="button"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="flex h-10 w-10 items-center justify-center lg:hidden"
        >
          <span class="sr-only">Open menu</span>
          <svg
            id="icon-open"
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-white"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
          </svg>
          <svg
            id="icon-close"
            xmlns="http://www.w3.org/2000/svg"
            class="hidden h-6 w-6 text-neutral-900"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu panel -->
      <div
        id="mobile-menu"
        class="hidden border-t border-neutral-200 bg-white lg:hidden"
      >
        <ul class="flex flex-col px-5 py-4 sm:px-8">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="mobile-link block border-b border-neutral-100 py-3 text-sm font-light tracking-wide text-neutral-700 hover:text-neutral-900"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="pt-4">
            <a
              href="#contact"
              class="mobile-link block rounded-full border border-neutral-900 px-5 py-3 text-center text-sm font-light tracking-wide text-neutral-900 hover:bg-neutral-900 hover:text-white"
            >
              Get in Touch
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main>
      <!-- ===================== HERO ===================== -->
      <section id="home" class="relative h-screen min-h-[600px] w-full">
        <SmartImage
          src={content.hero_image}
          alt={content.hero_image_alt}
          width={1600}
          height={1000}
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <!-- Dark gradient scrim at the bottom for legibility -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/10"
        >
        </div>
        <!-- Soft top scrim so the nav reads over the bright sky -->
        <div
          class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-black/50 to-transparent"
        >
        </div>

        <div
          class="relative z-10 mx-auto flex h-full max-w-7xl flex-col justify-end px-5 pb-24 sm:px-8 sm:pb-28 lg:px-12"
        >
          <h1
            class="max-w-3xl font-serif text-3xl font-medium leading-tight text-white text-balance [text-shadow:0_2px_16px_rgba(0,0,0,0.55)] sm:text-4xl md:text-4xl lg:text-5xl"
          >
            {content.hero_heading}
          </h1>
        </div>

        <!-- Scroll-down cue -->
        <a
          href="#about"
          aria-label="Scroll down to learn more"
          class="absolute bottom-8 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 text-white/80 transition-colors hover:text-white"
        >
          <span class="text-[11px] font-light uppercase tracking-[0.25em]">Scroll</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 animate-bounce"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </a>
      </section>

      <!-- ===================== INTRO / ABOUT ===================== -->
      <section id="about" class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12">
        <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16">
          <div class="order-1 lg:order-none">
            <SmartImage
              src={content.about_photo}
              alt={content.about_photo_alt}
              width={1000}
              height={1250}
              loading="lazy"
              class="aspect-[4/5] w-full rounded-sm object-cover"
            />
          </div>
          <div class="text-center lg:text-left">
            <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
              {content.about_eyebrow}
            </p>
            <h2 class="font-serif text-3xl font-medium leading-snug text-neutral-900 text-balance sm:text-4xl">
              {content.about_heading}
            </h2>
            <div class="mx-auto mt-8 max-w-xl space-y-5 text-lg font-light leading-relaxed text-neutral-600 text-pretty lg:mx-0">
              {content.about_paragraphs.map((para) => <p>{para}</p>)}
            </div>
          </div>
        </div>
      </section>

      <!-- ===================== PORTFOLIO ===================== -->
      <section
        id="portfolio"
        class="bg-neutral-50 px-5 py-24 sm:px-8 sm:py-28 lg:px-12"
      >
        <div class="mx-auto max-w-6xl">
          <div class="mb-10 flex flex-col gap-3 sm:mb-12 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="mb-3 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
                {content.portfolio_eyebrow}
              </p>
              <h2 class="font-serif text-3xl font-medium tracking-tight text-neutral-900 sm:text-4xl">
                {content.portfolio_heading}
              </h2>
            </div>
            <p class="max-w-sm text-sm leading-relaxed text-neutral-500">
              {content.portfolio_blurb}
            </p>
          </div>

          <div class="grid auto-rows-[180px] grid-cols-1 gap-4 sm:auto-rows-[220px] sm:grid-cols-2 md:grid-cols-4">
            {
              content.galleries.map((g, i) => (
                <a
                  href={g.href}
                  class={`group relative block overflow-hidden bg-neutral-100 ${g.span}`}
                >
                  <SmartImage
                    src={g.img}
                    alt={g.alt}
                    width={800}
                    height={1000}
                    loading={i < 2 ? "eager" : "lazy"}
                    class={`h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 ${g.ratio}`}
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/70 via-neutral-900/0 to-transparent" />
                  <div class="absolute inset-x-0 bottom-0 flex items-center justify-between p-4">
                    <h3 class="font-serif text-lg text-white drop-shadow-sm sm:text-xl">
                      {g.title}
                    </h3>
                    <span class="text-xs font-medium uppercase tracking-[0.2em] text-white/80 opacity-0 transition-opacity group-hover:opacity-100">
                      View
                    </span>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ===================== SERVICES & PRICING ===================== -->
      <section id="services" class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12">
        <div class="mx-auto max-w-3xl">
          <div class="mb-12 text-center">
            <p class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
              {content.services_eyebrow}
            </p>
            <h2 class="font-serif text-3xl font-medium text-neutral-900 sm:text-4xl">
              {content.services_heading}
            </h2>
            <p class="mx-auto mt-6 max-w-xl text-base font-light leading-relaxed text-neutral-600 text-pretty">
              {content.services_blurb}
            </p>
          </div>

          <ul class="divide-y divide-neutral-200 border-y border-neutral-200">
            {
              content.services.map((s) => (
                <li class="flex items-baseline justify-between gap-4 py-5">
                  <span class="font-serif text-xl text-neutral-900">{s.name}</span>
                  <span aria-hidden="true" class="mx-3 hidden flex-1 border-b border-dotted border-neutral-300 sm:block"></span>
                  <span class="tabular-nums text-neutral-600">{s.price}</span>
                </li>
              ))
            }
          </ul>

          <p class="mt-8 text-center text-sm font-light leading-relaxed text-neutral-500 text-pretty">
            {content.services_footnote}
          </p>
        </div>
      </section>

      <!-- ===================== PAY WHAT YOU CAN BAND ===================== -->
      <section
        id="mini-sessions"
        class="bg-neutral-900 px-5 py-24 text-center sm:px-8 sm:py-28 lg:px-12"
      >
        <div class="mx-auto max-w-3xl">
          <p
            class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500"
          >
            {content.minis_eyebrow}
          </p>
          <h2
            class="font-serif text-3xl font-medium leading-snug text-white text-balance sm:text-4xl"
          >
            {content.minis_heading}
          </h2>
          <p
            class="mx-auto mt-8 max-w-2xl text-lg font-light leading-relaxed text-neutral-300 text-pretty"
          >
            {content.minis_body_before}
            <span class="text-white">{content.minis_body_emphasis}</span>
            {content.minis_body_after}
          </p>
          <a
            href={content.minis_button_href}
            class="mt-10 inline-block rounded-full border border-white/70 px-7 py-3 text-sm font-light uppercase tracking-[0.15em] text-white transition-colors hover:bg-white hover:text-neutral-900"
          >
            {content.minis_button_label}
          </a>
        </div>
      </section>

      <!-- ===================== TESTIMONIALS CAROUSEL ===================== -->
      <section
        id="testimonials"
        class="bg-white px-5 py-24 sm:px-8 sm:py-32 lg:px-12"
      >
        <div class="mx-auto max-w-6xl">
          <div class="mb-12 flex flex-col gap-4 text-center sm:flex-row sm:items-end sm:justify-between sm:text-left">
            <div>
              <p class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
                {content.testimonials_eyebrow}
              </p>
              <h2 class="font-serif text-3xl font-medium text-neutral-900 sm:text-4xl">
                {content.testimonials_heading}
              </h2>
            </div>
            <div class="flex items-center justify-center gap-3 sm:justify-end">
              <button
                id="tst-prev"
                type="button"
                aria-label="Previous testimonial"
                class="flex h-11 w-11 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                </svg>
              </button>
              <button
                id="tst-next"
                type="button"
                aria-label="Next testimonial"
                class="flex h-11 w-11 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                </svg>
              </button>
            </div>
          </div>

          <div
            id="tst-track"
            class="flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth pb-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
          >
            {
              content.testimonials.map((t) => (
                <figure class="w-[85%] flex-shrink-0 snap-start border border-neutral-200 bg-neutral-50 p-8 sm:w-[60%] sm:p-10 lg:w-[46%]">
                  <blockquote class="font-serif text-lg font-normal italic leading-relaxed text-neutral-800 text-pretty sm:text-xl">
                    &ldquo;{t.quote}&rdquo;
                  </blockquote>
                  <figcaption class="mt-6 text-sm font-medium uppercase tracking-[0.2em] text-neutral-500">
                    — {t.author}
                  </figcaption>
                </figure>
              ))
            }
          </div>

          <div class="mt-10 text-center">
            <a
              href={content.testimonials_link_href}
              class="inline-block text-sm font-medium uppercase tracking-[0.2em] text-neutral-900 underline underline-offset-4 transition-colors hover:text-neutral-600"
            >
              {content.testimonials_link_label}
            </a>
          </div>
        </div>
      </section>

      <!-- ===================== CLOSING CTA ===================== -->
      <section id="contact" class="relative w-full">
        <SmartImage
          src={content.cta_image}
          alt={content.cta_image_alt}
          width={1600}
          height={900}
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-black/60"></div>

        <div
          class="relative z-10 mx-auto flex max-w-3xl flex-col items-center px-5 py-32 text-center sm:px-8 sm:py-40 lg:px-12"
        >
          <h2
            class="font-serif text-4xl font-medium leading-tight text-white text-balance sm:text-5xl"
          >
            {content.cta_heading}
          </h2>
          <p
            class="mt-6 max-w-xl text-lg font-light leading-relaxed text-white/80 text-pretty"
          >
            {content.cta_text}
          </p>
          <a
            href={content.cta_button_href}
            class="mt-10 inline-block rounded-full bg-white px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-colors hover:bg-neutral-200"
          >
            {content.cta_button_label}
          </a>
        </div>
      </section>
    </main>

    <!-- ===================== FOOTER ===================== -->
    <footer class="bg-white px-5 py-16 sm:px-8 lg:px-12">
      <div class="mx-auto max-w-7xl">
        <div
          class="flex flex-col items-center gap-8 border-b border-neutral-200 pb-12 text-center"
        >
          <a href="#home" aria-label="Meredith Lewis Photography — home">
            <img
              src="/logo.png"
              alt="Meredith Lewis Photography — based in the White Mountains, ME, NH &amp; VT, established 2019."
              width="760"
              height="485"
              class="h-64 w-auto sm:h-80"
            />
          </a>

          <nav aria-label="Footer" class="flex flex-wrap justify-center gap-x-6 gap-y-3">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="text-sm font-light tracking-wide text-neutral-800 transition-colors hover:text-neutral-900"
                >
                  {link.label}
                </a>
              ))
            }
          </nav>

          <div class="flex items-center gap-3">
            <a
              href="https://www.facebook.com/share/1Ew67obhv6/?mibextid=wwXIfr"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit Meredith Lewis Photography on Facebook"
              class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.89h2.54V9.797c0-2.507 1.492-3.892 3.777-3.892 1.094 0 2.238.196 2.238.196v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z"
                ></path>
              </svg>
            </a>
            <a
              href="mailto:meredith.lewis2018@gmail.com"
              aria-label="Email Meredith Lewis Photography"
              class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </a>
            <a
              href="https://meredithlewisphotography.pixieset.com/booking/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Book a session on Pixieset"
              class="flex h-10 items-center justify-center rounded-full border border-neutral-300 px-4 text-xs font-medium uppercase tracking-[0.18em] text-neutral-700 transition-colors hover:border-neutral-900 hover:text-neutral-900"
            >
              Book
            </a>
          </div>
        </div>

        <p class="mt-8 text-center text-xs font-light tracking-wide text-neutral-700">
          &copy; {new Date().getFullYear()} Meredith Lewis Photography. All rights reserved.
        </p>
      </div>
    </footer>

    <!-- ===================== VANILLA JS ===================== -->
    <script>
      // Nav background on scroll
      const nav = document.getElementById("site-nav");
      const wordmark = document.getElementById("wordmark");
      const navLinkEls = document.querySelectorAll(".nav-link");
      const navCta = document.querySelector(".nav-cta");
      const iconOpenEl = document.getElementById("icon-open");

      const onScroll = () => {
        const scrolled = window.scrollY > 40;
        if (scrolled) {
          nav?.classList.add("bg-white", "shadow-sm");
          wordmark?.classList.remove("text-white");
          wordmark?.classList.add("text-neutral-900");
          navLinkEls.forEach((el) => {
            el.classList.remove("text-white/90", "hover:text-white");
            el.classList.add("text-neutral-700", "hover:text-neutral-900");
          });
          navCta?.classList.remove("border-white/70", "text-white", "hover:bg-white", "hover:text-neutral-900");
          navCta?.classList.add("border-neutral-900", "text-neutral-900", "hover:bg-neutral-900", "hover:text-white");
          iconOpenEl?.classList.remove("text-white");
          iconOpenEl?.classList.add("text-neutral-900");
        } else {
          nav?.classList.remove("bg-white", "shadow-sm");
          wordmark?.classList.add("text-white");
          wordmark?.classList.remove("text-neutral-900");
          navLinkEls.forEach((el) => {
            el.classList.add("text-white/90", "hover:text-white");
            el.classList.remove("text-neutral-700", "hover:text-neutral-900");
          });
          navCta?.classList.add("border-white/70", "text-white", "hover:bg-white", "hover:text-neutral-900");
          navCta?.classList.remove("border-neutral-900", "text-neutral-900", "hover:bg-neutral-900", "hover:text-white");
          iconOpenEl?.classList.add("text-white");
          iconOpenEl?.classList.remove("text-neutral-900");
        }
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Mobile menu toggle
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const iconOpen = document.getElementById("icon-open");
      const iconClose = document.getElementById("icon-close");

      const closeMenu = () => {
        menu?.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        toggle?.setAttribute("aria-expanded", "false");
      };

      toggle?.addEventListener("click", () => {
        const isOpen = !menu?.classList.contains("hidden");
        if (isOpen) {
          closeMenu();
        } else {
          menu?.classList.remove("hidden");
          iconOpen?.classList.add("hidden");
          iconClose?.classList.remove("hidden");
          toggle?.setAttribute("aria-expanded", "true");
        }
      });

      // Close mobile menu when a link is tapped
      document.querySelectorAll(".mobile-link").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      // Testimonial carousel
      const tstTrack = document.getElementById("tst-track");
      const tstPrev = document.getElementById("tst-prev");
      const tstNext = document.getElementById("tst-next");

      if (tstTrack && tstPrev && tstNext) {
        const scrollByCard = (dir: number) => {
          const card = tstTrack.querySelector("figure");
          const amount = card ? card.offsetWidth + 24 : tstTrack.clientWidth * 0.8;
          tstTrack.scrollBy({ left: dir * amount, behavior: "smooth" });
        };
        tstPrev.addEventListener("click", () => scrollByCard(-1));
        tstNext.addEventListener("click", () => scrollByCard(1));
      }
    </script>
  </body>
</html>
