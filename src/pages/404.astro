---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found | Meredith Lewis Photography"
  description="The page you're looking for couldn't be found. Head back to the Meredith Lewis Photography homepage."
  noindex={true}
>
  <section class="flex min-h-[70vh] items-center justify-center px-5 py-32 sm:px-8">
    <div class="mx-auto max-w-xl text-center">
      <p class="mb-6 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">
        Page Not Found
      </p>
      <h1 class="font-serif text-6xl font-medium leading-none text-neutral-900 sm:text-7xl">
        404
      </h1>
      <p class="mx-auto mt-8 max-w-md text-lg font-light leading-relaxed text-neutral-600 text-pretty">
        The page you&apos;re looking for seems to have wandered off the trail.
        Let&apos;s get you back to familiar ground.
      </p>
      <a
        href="/"
        class="mt-10 inline-block rounded-full bg-neutral-900 px-8 py-3 text-sm font-medium uppercase tracking-[0.15em] text-white transition-colors hover:bg-neutral-700"
      >
        Back to Home
      </a>
    </div>
  </section>
</Layout>
